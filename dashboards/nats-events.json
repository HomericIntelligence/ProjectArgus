{
  "title": "NATS Event Bus",
  "uid": "nats-events",
  "version": 1,
  "schemaVersion": 38,
  "tags": ["nats", "messaging"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Messages In / sec",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(nats_in_msgs_total[1m])",
          "legendFormat": "msgs/s in",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 2,
      "title": "Messages Out / sec",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(nats_out_msgs_total[1m])",
          "legendFormat": "msgs/s out",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 3,
      "title": "JetStream Storage Used",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nats_jetstream_bytes",
          "legendFormat": "Storage",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 4,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "nats_connections",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      }
    },
    {
      "id": 5,
      "title": "Message Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(nats_in_msgs_total[1m])",
          "legendFormat": "In msg/s",
          "refId": "A"
        },
        {
          "expr": "rate(nats_out_msgs_total[1m])",
          "legendFormat": "Out msg/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "title": "Bytes In/Out Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(nats_in_bytes_total[1m])",
          "legendFormat": "Bytes in/s",
          "refId": "A"
        },
        {
          "expr": "rate(nats_out_bytes_total[1m])",
          "legendFormat": "Bytes out/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    }
  ]
}
