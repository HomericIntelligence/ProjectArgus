{
  "title": "Task Throughput",
  "uid": "task-throughput",
  "version": 1,
  "schemaVersion": 38,
  "tags": ["tasks", "pipeline"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Tasks Created / hour",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(hi_tasks_by_status[1h])",
          "legendFormat": "Created",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 2,
      "title": "Tasks Completed / hour",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hi_tasks_by_status{status=\"completed\"}",
          "legendFormat": "Completed",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 3,
      "title": "Tasks Failed / hour",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hi_tasks_by_status{status=\"failed\"}",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 5,
      "title": "Task Rate Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(hi_tasks_by_status[1h])",
          "legendFormat": "Total/hr",
          "refId": "A"
        },
        {
          "expr": "hi_tasks_by_status{status=\"completed\"}",
          "legendFormat": "Completed",
          "refId": "B"
        },
        {
          "expr": "hi_tasks_by_status{status=\"failed\"}",
          "legendFormat": "Failed",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    }
  ]
}
